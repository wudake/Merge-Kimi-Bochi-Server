# ─────────────────────────────────────────────────────────────────────────────
# Unified 系统环境变量
#
# 用法:
#   1. cp .env.example .env
#   2. 修改下面所有标记 "请改为..." 的值
#   3. .env 不要提交到 git(已在 .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ─── 域名 ───
# 你的主域名(整合系统将挂在 app.${MAIN_DOMAIN} 子域)
MAIN_DOMAIN=example.com

# ─── PostgreSQL ───
PG_USER=opman
PG_PASSWORD=请改为强密码至少16位

# ─── Redis ───
# 默认无密码(因为只在 Docker 内网访问);如需密码,redis 服务的 command 需加 --requirepass
# REDIS_PASSWORD=

# ─── JWT (Operation_Manage 使用,且作为 SSO 唯一签发源) ───
JWT_SECRET=请改为至少32位的强随机字符串
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ─── OpenAI Whisper API (FB-SE 可选,使用付费 API 时填) ───
OPENAI_API_KEY=

# ─── 鉴权模式 ───
# nginx_header: 子项目读 Nginx 注入的 X-User-Id (推荐,Phase 4+ 启用)
# legacy:       保留各项目原有鉴权 (API_KEY / 硬编码密码),用于过渡期
AUTH_MODE=nginx_header
